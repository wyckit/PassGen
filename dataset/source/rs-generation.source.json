  "Concepts": [
    {
      "Id": "gen-root",
      "Label": "generation algorithm",
      "Category": "Algorithm",
      "Description": "Deterministic generator: validate spec -\u003E place mandatory minimums -\u003E uniform-fill the remainder -\u003E validate output (-\u003E repair if needed).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "step-validate-spec",
      "Label": "validate spec",
      "Category": "Step",
      "Description": "Feasibility check before any sampling (validate_spec).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "step-place-minimums",
      "Label": "place minimums",
      "Category": "Step",
      "Description": "Place each class\u0027s guaranteed minimum first, sampled within-class uniformly.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "step-fill-uniform",
      "Label": "uniform fill",
      "Category": "Step",
      "Description": "Fill remaining positions by sampling uniformly from the UNION of all allowed, non-maxed characters.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "step-validate-output",
      "Label": "validate output",
      "Category": "Step",
      "Description": "Verify the produced string satisfies the spec (validator.check).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "step-repair",
      "Label": "repair",
      "Category": "Step",
      "Description": "Relax infeasible/over-constrained predictions and retry.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "rng-csprng",
      "Label": "CSPRNG",
      "Category": "Rng",
      "Description": "Cryptographically secure RNG (RandomNumberGenerator / secrets.SystemRandom). Used by default (seed is null) for real passwords.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "rng-seeded",
      "Label": "seeded PRNG",
      "Category": "Rng",
      "Description": "Reproducible Mersenne-Twister RNG used ONLY when an explicit int seed is given (tests/demos).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "risk-mt-insecure",
      "Label": "Mersenne Twister is not secure",
      "Category": "Risk",
      "Description": "MT state is reconstructable from ~624 outputs \u2014 never use for real passwords.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "bias-per-class",
      "Label": "per-class sampling bias",
      "Category": "Antipattern",
      "Description": "Picking a class first then a char within it over-represents small classes (digits ~2.6x). Avoided by flat union sampling.",
      "Aliases": [],
      "Properties": {}
    }
  ],
