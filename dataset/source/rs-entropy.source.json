      "Properties": {
        "Bits": "80"
      }
    },
    {
      "Id": "ins-length-dominates",
      "Label": "length dominates charset",
      "Category": "Insight",
      "Description": "Doubling length (8-\u003E16) roughly doubles entropy (~50-\u003E100 bits); adding character variety adds far less.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "ins-symbol-marginal",
      "Label": "symbols add little",
      "Category": "Insight",
      "Description": "Adding the symbol class to a 16-char alphanumeric password adds only ~4 bits (95.3-\u003E99.7).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "ins-perclass-min-reduces",
      "Label": "per-class minimums reduce entropy",
      "Category": "Insight",
      "Description": "Forcing structure (\u0027at least 2 of each\u0027) slightly shrinks the valid space (99.7-\u003E98.6 bits).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "ins-no-ambiguous-costs",
      "Label": "no-ambiguous costs ~2 bits",
      "Category": "Insight",
      "Description": "Dropping ambiguous chars shrinks the charset 75-\u003E69, costing ~2 bits.",
      "Aliases": [],
      "Properties": {}
    }
