    {
      "Id": "entropy-root",
      "Label": "password entropy",
      "Category": "Metric",
      "Description": "Strength model: entropy = log2(number of distinct valid strings) = the attacker search space, in bits.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "metric-bits",
      "Label": "bits",
      "Category": "Metric",
      "Description": "log2 of the count of distinct valid strings the spec admits.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "metric-charset",
      "Label": "charset size",
      "Category": "Metric",
      "Description": "Number of distinct characters usable under the spec (N).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "metric-valid-count",
      "Label": "valid string count",
      "Category": "Metric",
      "Description": "Exact count via the constrained-multinomial EGF; reduces to N^L when unconstrained.",
      "Aliases": [],
      "Properties": {}
    },
    {
