  "Concepts": [
    {
      "Id": "spec-root",
      "Label": "ConstraintSpec",
      "Category": "Schema",
      "Description": "The structured contract that is the single source of truth between the natural-language front end and the deterministic generator. JSON shape: { length:{exact,min,max}, classes:{\u003Cclass\u003E-\u003E{allowed,min,max}}, exclude_chars[], include_chars[] }.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "field-length",
      "Label": "length",
      "Category": "SpecField",
      "Description": "Length constraint: exact, or a [min,max] range.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "field-classes",
      "Label": "classes",
      "Category": "SpecField",
      "Description": "Per-class allow/min/max constraints for the four character classes.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "field-exclude",
      "Label": "exclude_chars",
      "Category": "SpecField",
      "Description": "Explicit characters the output must never contain.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "field-include",
      "Label": "include_chars",
      "Category": "SpecField",
      "Description": "Explicit characters the output must contain at least once.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "slot-length-exact",
      "Label": "length.exact",
      "Category": "SpecSlot",
      "Description": "Exact required length (mutually exclusive with min/max).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "slot-length-min",
      "Label": "length.min",
      "Category": "SpecSlot",
      "Description": "Minimum length bound.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "slot-length-max",
      "Label": "length.max",
      "Category": "SpecSlot",
      "Description": "Maximum length bound (default cap, e.g. 16).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "slot-allowed",
      "Label": "class.allowed",
      "Category": "SpecSlot",
      "Description": "Whether characters from this class may appear (boolean gate).",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "slot-class-min",
      "Label": "class.min",
      "Category": "SpecSlot",
      "Description": "Guaranteed minimum count of characters from this class.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "slot-class-max",
      "Label": "class.max",
      "Category": "SpecSlot",
      "Description": "Maximum count of characters from this class.",
      "Aliases": [],
      "Properties": {}
    },
    {
      "Id": "cc-uppercase",
      "Label": "uppercase constraint",
      "Category": "ClassConstraint",
      "Description": "Allow/min/max constraint record for the uppercase class.",
      "Aliases": [],
      "Properties": {
        "Class": "uppercase"
      }
    },
    {
      "Id": "cc-lowercase",
      "Label": "lowercase constraint",
      "Category": "ClassConstraint",
      "Description": "Allow/min/max constraint record for the lowercase class.",
      "Aliases": [],
      "Properties": {
        "Class": "lowercase"
      }
    },
    {
      "Id": "cc-numeric",
      "Label": "numeric constraint",
      "Category": "ClassConstraint",
      "Description": "Allow/min/max constraint record for the numeric class.",
      "Aliases": [],
      "Properties": {
        "Class": "numeric"
      }
    },
    {
      "Id": "cc-symbol",
      "Label": "symbol constraint",
